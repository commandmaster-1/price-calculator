{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "price-calculator",
  "version": "0.1.3",
  "identifier": "com.cmd.price-calculator",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Preisrechner",
        "width": 1000,
        "height": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYyOTNDRkZEN0VEQzc0MkEKUldRcWROeCsvYytUOG9qc2FwUXV4YkJpWXhpdHhUeWs3VzlsWVM2TEpzNko0cjVPL0oxZWhPcUwK",
      "endpoints": [
        "https://github.com/commandmaster-1/price-calculator/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
